# Copy to lab.env.local and fill in from Supabase Dashboard → Project Settings → API
# NEVER commit lab.env.local

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_anon_public_key_here

# Lab accounts — passwords MUST match what you used in the Flutter app signup
# (NOT the placeholder below). Run: ./scripts/security/idor_tests.sh --check-auth
ATTACKER_EMAIL=attacker@test.com
ATTACKER_PASSWORD=replace_with_real_attacker_password
VICTIM_EMAIL=victim@test.com
VICTIM_PASSWORD=replace_with_real_victim_password

# Fill after seeding victim data (Settings → Sync, or run idor_tests.sh --discover-victim)
VICTIM_CUSTOMER_ID=
VICTIM_SHOP_ID=
